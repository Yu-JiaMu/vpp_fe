                            "dataType": {
                                "type": "int",
                                "specs": {
                                    "max": "100",
                                    "min": "0",
                                    "step": "1",
                                    "unit": ""
                                }
                            }
                        }
                    ],
                    "functionMode": "event"
                }
            ],
            "functions": [
